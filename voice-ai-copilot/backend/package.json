{
  "name": "@voice-ai-copilot/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/workers/temporal-worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "migrate": "ts-node src/db/migrate.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "simulate": "ts-node src/scripts/simulate-webhook.ts",
    "simulate:all": "ts-node src/scripts/simulate-webhook.ts all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@temporalio/activity": "^1.10.2",
    "@temporalio/client": "^1.10.2",
    "@temporalio/worker": "^1.10.2",
    "@temporalio/workflow": "^1.10.2",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.16.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
