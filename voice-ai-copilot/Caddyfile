{$DUCKDNS_DOMAIN} {
	encode gzip

	route {
		handle /api/* {
			reverse_proxy app:3000
		}

		handle /stream* {
			reverse_proxy app:3000 {
				flush_interval -1
			}
		}

		handle /webhooks/* {
			reverse_proxy app:3000
		}

		handle /oauth/* {
			reverse_proxy app:3000
		}

		handle /health {
			reverse_proxy app:3000
		}

		handle {
			root * /srv/frontend
			try_files {path} /index.html
			file_server
		}
	}
}
