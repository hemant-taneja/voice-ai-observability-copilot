# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_copilot

# Database password (used by Docker Compose for postgres + Temporal)
POSTGRES_PASSWORD=change-me-in-production

# DuckDNS subdomain for HTTPS (e.g. voice-copilot.duckdns.org)
DUCKDNS_DOMAIN=your-subdomain.duckdns.org

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# GHL — from your app in https://marketplace.gohighlevel.com
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# GHL_WEBHOOK_SECRET is only used by the legacy /webhooks/call-completed endpoint
GHL_WEBHOOK_SECRET=your-webhook-secret-here
# GHL_WEBHOOK_PUBLIC_KEY — optional override for GHL's Ed25519 public key.
# This is GHL's public key (not a secret). Only set this if GHL rotates their key.
# GHL_WEBHOOK_PUBLIC_KEY=

# Your deployed backend URL — used as the OAuth redirect URI and webhook base
# Must match exactly what you registered in GHL app settings (no trailing slash)
APP_URL=https://voice-agent-copilot.duckdns.org

# LLM — supported: openai, anthropic, groq
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# App
PORT=3000
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:3000
