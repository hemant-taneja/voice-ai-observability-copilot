# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_copilot

# Database password (used by Docker Compose for postgres + Temporal)
POSTGRES_PASSWORD=change-me-in-production

# DuckDNS subdomain for HTTPS (e.g. voice-copilot.duckdns.org)
DUCKDNS_DOMAIN=your-subdomain.duckdns.org

# Redis
REDIS_URL=redis://localhost:6379

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# GHL
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_WEBHOOK_SECRET=your-webhook-secret-here

# LLM — supported: openai, anthropic, groq
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# App
PORT=3000
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:3000
